edback.js","original":{"line":50,"column":0},"name":"loadFormState"},{"generated":{"line":40,"column":13},"source":"js/03-feedback.js","original":{"line":50,"column":13}},{"generated":{"line":40,"column":14},"source":"js/03-feedback.js","original":{"line":50,"column":14}},{"generated":{"line":40,"column":15},"source":"js/03-feedback.js","original":{"line":50,"column":15}},{"generated":{"line":41,"column":0},"source":"js/03-feedback.js","original":{"line":51,"column":0}},{"generated":{"line":41,"column":6},"source":"js/03-feedback.js","original":{"line":51,"column":6},"name":"hello"},{"generated":{"line":41,"column":11},"source":"js/03-feedback.js","original":{"line":51,"column":11}},{"generated":{"line":41,"column":14},"source":"js/03-feedback.js","original":{"line":51,"column":14}},{"generated":{"line":41,"column":15},"source":"js/03-feedback.js","original":{"line":51,"column":15}}],"sources":{"js/03-feedback.js":"\nimport throttle from 'lodash.throttle';\n\nconst form = document.querySelector('.feedback-form');\nconst emailInput = form.querySelector('input[name=\"email\"]');\nconst messageInput = form.querySelector('textarea[name=\"message\"]');\n\nconst saveFormState = () => {\n  const formState = {\n    email: emailInput.value,\n    message: messageInput.value,\n  };\n\n  localStorage.setItem('feedback-form-state', JSON.stringify(formState));\n};\n\nconst loadFormState = () => {\n  const savedFormState = localStorage.getItem('feedback-form-state');\n\n  if (savedFormState) {\n    const parsedFormState = JSON.parse(savedFormState);\n    emailInput.value = parsedFormState.email;\n    messageInput.value = parsedFormState.message;\n  }\n};\n\nconst handleSubmit = (event) => {\n  event.preventDefault();\n\n  const formState = {\n    email: emailInput.value,\n    message: messageInput.value,\n  };\n\n  console.log(formState);\n\n  localStorage.removeItem('feedback-form-state');\n  emailInput.value = '';\n  messageInput.value = '';\n};\n\nconst handleInput = throttle(() => {\n  saveFormState();\n}, 500);\n\nemailInput.addEventListener('input', handleInput);\nmessageInput.addEventListener('input', handleInput);\nform.addEventListener('submit', handleSubmit);\n\nloadFormState();\nconst hello = 1;"},"lineCount":null}},"error":null,"hash":"4a08ebe76deca09f4ea23529cbc3a899","cacheData":{"env":{}}}